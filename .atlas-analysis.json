  "keyFeatures": [
    "Migrate Work Items (with full history, attachments, and links) between TFS and Azure DevOps",
    "Migrate Test Plans, Test Suites, Shared Steps, and Test Configurations",
    "Copy Pipelines between Azure DevOps projects and organizations",
    "Bulk edit Work Items in-place for process template changes or data cleanup",
    "Flexible field mapping system with regex, value, merge, and calculation maps",
    "Node structure (Area/Iteration) remapping with regex-based path transformations",
    "User identity mapping between source and target organizations",
    "Team settings migration including capacities and sprint assignments",
    "WIQL-based work item filtering for selective migrations",
    "Installation via Winget, Chocolatey, or manual ZIP download"
  ],
  "publicApiSurface": [
    "devopsmigration init --options <Basic|Full|WorkItemTracking|Fullv2|WorkItemTrackingv2>",
